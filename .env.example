# ============================================================================
# gBOMBS Environment Variables — TEMPLATE (safe to commit)
# Copy this file to .env and fill in real values. Never commit the real .env.
# ============================================================================

# ===== SUPABASE =====
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== GOOGLE GEMINI =====
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ===== GOOGLE OAUTH =====
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_oauth_android_client_id
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_oauth_ios_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ===== STRIPE =====
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_ID_STANDARD=price_id_for_1999_monthly
STRIPE_PRICE_ID_CHEF=price_id_for_4999_monthly

# ===== REVENUE CAT =====
EXPO_PUBLIC_REVENUECAT_ANDROID=your_revenuecat_android_key
EXPO_PUBLIC_REVENUECAT_IOS=your_revenuecat_ios_key

# ===== INSTACART =====
INSTACART_API_KEY=your_instacart_api_key
INSTACART_CLIENT_ID=your_instacart_client_id

# ===== UNSPLASH =====
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ===== USDA NUTRITION =====
USDA_API_KEY=your_usda_api_key

# ===== EXPO =====
EXPO_ACCESS_TOKEN=your_expo_access_token

# ===== INSTAGRAM (PHASE 2) =====
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# ===== GOOGLE IMAGEN (PHASE 2) =====
IMAGEN_API_KEY=your_imagen_api_key
